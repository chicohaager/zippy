{
  "build": {
    "devUrl": "http://YOUR-BACKEND-HOST:7860"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zippy",
        "url": "http://YOUR-BACKEND-HOST:7860",
        "width": 380,
        "height": 620,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": false,
        "shadow": true,
        "focus": true,
        "acceptFirstMouse": true,
        "devtools": true,
        "additionalBrowserArgs": "--autoplay-policy=no-user-gesture-required --unsafely-treat-insecure-origin-as-secure=http://YOUR-BACKEND-HOST:7860"
      }
    ]
  }
}
