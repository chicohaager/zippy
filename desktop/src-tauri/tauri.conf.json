{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zippy",
  "version": "0.1.0",
  "identifier": "info.virtual-services.zippy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://REDACTED_HOST:7860"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zippy",
        "url": "http://REDACTED_HOST:7860",
        "width": 380,
        "height": 620,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": false,
        "shadow": true,
        "focus": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
